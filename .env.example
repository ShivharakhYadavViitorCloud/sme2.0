# Copy to .env.local for local Docusaurus builds (never commit secrets).

# Google Analytics (optional) — injected at build time
# GTAG_ID=G-XXXXXXXXXX

# SME Node API base URL (no trailing path). Example dev: http://localhost:8787
# The site calls POST {PUBLIC_API_BASE_URL}/api/chat and POST .../api/feedback
# PUBLIC_API_BASE_URL=http://localhost:8787

# Server secrets live in server/.env — see server/.env.example
